<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header>
    <h1>Consumer Home</h1>
    <p class="welcome-text">Welcome, <%= user.name %></p>

   <p class="header-links">
  <a href="/consumer">Search Products</a>
  <span>|</span>
  <a href="/cart">My Cart</a>
  <span>|</span>
  <a href="/consumer/profile/edit">Edit Profile</a>
  <span>|</span>
  <a href="/logout">Logout</a>
</p>
  </header>

  <main>
    <section class="card">
      <h2>Search Products</h2>

      <form action="/consumer" method="GET" class="search-form">
        <input 
          type="text" 
          name="keyword" 
          placeholder="Search product name..."
          value="<%= keyword || '' %>"
        >

        <button type="submit">Search</button>
      </form>

      <% if (message) { %>
        <p class="error"><%= message %></p>
      <% } %>
    </section>

    <% if (products && products.length > 0) { %>
      <section class="card">
        <h2>Search Results</h2>

        <div class="consumer-product-grid">
          <% products.forEach(product => { %>

            <div class="consumer-product-card">
              <img src="<%= product.image %>" alt="<%= product.title %>">

              <h3><%= product.title %></h3>

              <p>
                <strong>Market:</strong>
                <%= product.market_name %>
              </p>

              <p>
                <strong>Location:</strong>
                <%= product.market_city %> / <%= product.market_district %>
              </p>

              <p>
                <strong>Stock:</strong>
                <%= product.stock %>
              </p>

              <p>
                <strong>Normal Price:</strong>
                <span class="old-price"><%= product.normal_price %> TL</span>
              </p>

              <p>
                <strong>Discounted Price:</strong>
                <span class="discount-price"><%= product.discounted_price %> TL</span>
              </p>

              <p>
                <strong>Expiration Date:</strong>
                <%= product.expiration_date.toISOString().slice(0, 10) %>
              </p>

              <p>
                <strong>Days Left:</strong>
                <%= product.days_left %>
              </p>
              <form action="/cart/add/<%= product.id %>" method="POST">
  <button type="submit">Add to Cart</button>
</form>
            </div>

          <% }) %>
        </div>

        <% if (totalPages > 1) { %>
          <div class="pagination">

            <% if (page > 1) { %>
              <a href="/consumer?keyword=<%= keyword %>&page=<%= page - 1 %>">Previous</a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a 
                href="/consumer?keyword=<%= keyword %>&page=<%= i %>"
                class="<%= page === i ? 'active-page' : '' %>"
              >
                <%= i %>
              </a>
            <% } %>

            <% if (page < totalPages) { %>
              <a href="/consumer?keyword=<%= keyword %>&page=<%= page + 1 %>">Next</a>
            <% } %>

          </div>
        <% } %>

      </section>
    <% } %>
  </main>

</body>
</html>