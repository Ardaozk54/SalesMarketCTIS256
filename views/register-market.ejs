<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header>
    <h1>Market Register</h1>
    <p>Create a market account</p>
  </header>

  <main>
    <section class="card">
      <form action="/register/market" method="POST">

        <label>Email</label>
        <input 
          type="text" 
          name="email" 
          value="<%= form.email || '' %>"
        >
        <% if (errors.email) { %>
          <p class="error"><%= errors.email.msg %></p>
        <% } %>

        <label>Market Name</label>
        <input 
          type="text" 
          name="name" 
          value="<%= form.name || '' %>"
        >
        <% if (errors.name) { %>
          <p class="error"><%= errors.name.msg %></p>
        <% } %>

        <label>Password</label>
        <input 
          type="password" 
          name="password"
        >
        <% if (errors.password) { %>
          <p class="error"><%= errors.password.msg %></p>
        <% } %>

        <label>City</label>
        <input 
          type="text" 
          name="city" 
          value="<%= form.city || '' %>"
        >
        <% if (errors.city) { %>
          <p class="error"><%= errors.city.msg %></p>
        <% } %>

        <label>District</label>
        <input 
          type="text" 
          name="district" 
          value="<%= form.district || '' %>"
        >
        <% if (errors.district) { %>
          <p class="error"><%= errors.district.msg %></p>
        <% } %>

        <button type="submit">Register</button>
      </form>

      <p>
        <a href="/register">Back</a>
      </p>
    </section>
  </main>

</body>
</html>